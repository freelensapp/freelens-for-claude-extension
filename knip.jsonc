{
  "$schema": "https://unpkg.com/knip@5/schema-jsonc.json",

  "entry": [
    "out/{main,preload}/index.js!",
    "src/main/index.ts",
    "src/renderer/index.tsx",
    "src/**/*.{test,spec}.{ts,tsx}",
    "test/**/*.{ts,tsx}"
  ],
  "project": ["*.{js,mjs,ts}", "out/**/*.js!", "src/**/*.{ts,tsx}"],

  "ignoreBinaries": ["electron-rebuild", "yq"],
  "ignoreDependencies": [
    // used as vite plugin
    "@babel/plugin-proposal-decorators",
    // TODO: currently unused because `src` is minimal; these are provided by the
    // Freelens host (react, react-dom, mobx, mobx-react) or used by tests and
    // will be needed again once real components/tests are added. Remove from
    // this list when they are imported by `src`.
    "@testing-library/react",
    "@types/react",
    "mobx",
    "mobx-react",
    "react",
    "react-dom"
  ],

  "typescript": {
    "config": ["tsconfig.json"]
  },
  "vite": {
    "config": ["electron.vite.config.js"]
  },

  "exclude": ["exports"]
}
