{
  "$schema": "https://unpkg.com/knip@5/schema-jsonc.json",

  "entry": [
    // Real extension entry points live in `src`. Mark them as production (`!`)
    // so `knip --production` traces dependencies from source instead of the
    // bundled `out/` output, where imports are inlined and thus invisible.
    "src/main/index.ts!",
    "src/renderer/index.tsx!",
    "src/**/*.{test,spec}.{ts,tsx}",
    "test/**/*.{ts,tsx}"
  ],
  // `src` files are production code (`!`) so `knip --production` follows
  // transitive imports from the entry points through the whole source tree.
  // Without the `!`, production mode only inspects the entry files themselves
  // and reports transitively-used runtime dependencies as unused.
  "project": ["*.{js,mjs,ts}", "src/**/*.{ts,tsx}!"],

  "ignoreBinaries": ["electron-rebuild", "yq"],
  "ignoreDependencies": [
    // used as a vite plugin, not imported directly
    "@babel/plugin-proposal-decorators",
    // provided by the Freelens host as globals at runtime (see the
    // `globalExternals` map in electron.vite.config.js); they are imported by
    // `src` but never bundled, so production mode would otherwise report them
    // as unlisted dependencies.
    "@freelensapp/extensions",
    "mobx",
    "mobx-react",
    "react",
    "react-dom",
    // the Electron runtime, provided by the Freelens host process. It is loaded
    // via a guarded `require("electron")` in `src/main/tools/cli-exec.ts` to read
    // `app.getPath("userData")` and kept `external` in the main build, so it is
    // intentionally not a listed dependency; knip would otherwise report it as
    // unlisted from both the source require and the surviving `out/` bundle.
    "electron",
    // types-only and test-only dev dependencies
    "@testing-library/react",
    "@types/react",
    // optional peer dependencies of node-fetch / ws (pulled in transitively by
    // @kubernetes/client-node). They are loaded via guarded `require(...)` in a
    // try/catch and kept `external` in the main build (see electron.vite.config.js),
    // so the guarded requires survive in `out/main/index.js`. They are intentionally
    // not installed, so knip would otherwise report them as unlisted dependencies.
    "encoding",
    "bufferutil",
    "utf-8-validate",
    // bundled into `out/` by electron-vite at build time (not marked `external`
    // in electron.vite.config.js), so the published package has no runtime
    // dependencies and these live in `devDependencies`. Production mode would
    // otherwise report them as unlisted.
    "@anthropic-ai/claude-agent-sdk",
    "@kubernetes/client-node",
    "diff",
    "react-markdown",
    "remark-gfm",
    "yaml",
    "zod"
  ],

  "typescript": {
    "config": ["tsconfig.json"]
  },
  "vite": {
    "config": ["electron.vite.config.js"]
  },

  "exclude": ["exports"]
}
